{
  "entities": {
    "Settings": {
      "title": "Settings",
      "description": "Global settings for the studio",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studio_name": { "type": "string" },
        "subtitle": { "type": "string" },
        "description": { "type": "string" },
        "contact_email": { "type": "string" },
        "contact_phone": { "type": "string" },
        "contact_address": { "type": "string" },
        "instagram_url": { "type": "string" },
        "footer_text": { "type": "string" },
        "theme": { "type": "string" },
        "watermark_enabled": { "type": "boolean" },
        "watermark_image_url": { "type": "string" }
      }
    },
    "Album": {
      "title": "Album",
      "description": "A photography portfolio collection",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "cover_image": { "type": "string" },
        "category": { "type": "string" },
        "location": { "type": "string" },
        "event_date": { "type": "string" },
        "is_private": { "type": "boolean" },
        "password": { "type": "string" },
        "created_at": { "type": "string" },
        "photo_count": { "type": "number" }
      },
      "required": ["id", "title", "cover_image", "category", "is_private", "created_at"]
    },
    "Photo": {
      "title": "Photo",
      "description": "An individual photograph inside an album",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "album_id": { "type": "string" },
        "url": { "type": "string" },
        "thumbnail_url": { "type": "string" },
        "filename": { "type": "string" },
        "width": { "type": "number" },
        "height": { "type": "number" },
        "aspect_ratio": { "type": "number" },
        "order": { "type": "number" },
        "created_at": { "type": "string" }
      },
      "required": ["id", "album_id", "url", "thumbnail_url", "filename", "order", "created_at"]
    },
    "PhotobookOrder": {
      "title": "PhotobookOrder",
      "description": "A photobook print and design order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "album_id": { "type": "string" },
        "album_title": { "type": "string" },
        "client_name": { "type": "string" },
        "client_email": { "type": "string" },
        "cover_title": { "type": "string" },
        "cover_subtitle": { "type": "string" },
        "layout_style": { "type": "string" },
        "book_size": { "type": "string" },
        "total_price": { "type": "number" },
        "payment_method": { "type": "string" },
        "payment_reference": { "type": "string" },
        "payment_sender_name": { "type": "string" },
        "payment_receipt_url": { "type": "string" },
        "status": { "type": "string" },
        "created_at": { "type": "string" },
        "delivery_address": { "type": "string" },
        "delivery_phone": { "type": "string" }
      },
      "required": ["id", "album_id", "album_title", "client_name", "client_email", "cover_title", "layout_style", "book_size", "total_price", "payment_method", "payment_reference", "payment_sender_name", "status", "created_at"]
    }
  },
  "firestore": {
    "settings/studio": {
      "schema": "Settings",
      "description": "Global studio configuration and layout settings"
    },
    "albums/{albumId}": {
      "schema": "Album",
      "description": "Portfolio albums and collections"
    },
    "photos/{photoId}": {
      "schema": "Photo",
      "description": "Individual photographs connected to portfolio albums"
    },
    "orders/{orderId}": {
      "schema": "PhotobookOrder",
      "description": "Clients designed and registered photobook orders"
    }
  }
}
